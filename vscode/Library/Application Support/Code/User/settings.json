{
    // Editor
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.minimap.enabled": false,
    "editor.renderControlCharacters": true,
    "editor.renderLineHighlight": "all",
    "editor.renderWhitespace": "all",
    "editor.suggestSelection": "first",
    "editor.snippetSuggestions": "top",

    // Workbench
    "workbench.colorTheme": "Gruvbox Dark (Soft)",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.colorCustomizations": {
        "statusBar.background": "#005f5f",
        "statusBar.noFolderBackground": "#005f5f",
        "statusBar.debuggingBackground": "#005f5f"
    },
    "workbench.sideBar.location": "left",
    "workbench.settings.useSplitJSON": true,

    // Window
    "window.newWindowDimensions": "maximized",
    "window.title": "${activeEditorMedium} ${dirty}",
    "window.zoomLevel": 0,

    // Material Icon
    "material-icon-theme.hidesExplorerArrows": false,
    "material-icon-theme.showWelcomeMessage": false,
    "material-icon-theme.hidesExplorerArrows": true,

    "beautify.language": { "js": [] },
    // Files
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/bower_components": true,
        "**/.sass-cache": true,
        ".nyc_output": true
    },
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.associations": {
        // Ansible
        "**/defaults/**/*.yml": "jinja-yaml",
        "**/group_vars/**/*": "jinja-yaml",
        "**/host_vars/**/*": "jinja-yaml",
        "**/vars/**/*.yml": "jinja-yaml",
        "**/tasks/**/*.yml": "ansible",
        "**/handlers/*.yml": "ansible",
        "**/meta/*.yml": "ansible",
        "**/roles/**/*.yml": "ansible",
        "**/playbooks/**/*.yml": "ansible",
        "**/ansible/**/hosts": "ini",
        "**/ansible/**/inventory": "ini",
        "ansible.cfg": "ini"
    },

    // Golang
    "go.lintTool": "golangci-lint",
    "go.lintFlags": [
        "--disable-all",
        "--enable=vet",
        "--enable=vetshadow",
        "--enable=golint",
        "--enable=ineffassign",
        "--enable=goconst",
        "--enable=gofmt",
        "--enable=goimports",
        "--deadline=2m",
        "--enable=bodyclose",
        "--enable=gosimple",
        "--enable=whitespace"
    ],
    "go.useLanguageServer": true,
    "go.languageServerFlags": [],
    "go.useCodeSnippetsOnFunctionSuggest": true,

    // Integrated terminal
    "terminal.external.osxExec": "iterm2",
    "terminal.integrated.shell.osx": "/bin/zsh",
    "terminal.integrated.fontFamily": "'SauceCodePro Nerd Font'",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontWeight": "600",

    // Breadcrumbs
    "breadcrumbs.enabled": false,

    // SCM
    "scm.defaultViewMode": "tree",

    // Vim
    "vim.leader": "<space>",
    "vim.incsearch": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.surround": false,
    "vim.neovimPath": "/usr/local/bin/nvim",
    "vim.enableNeovim": true,

    // Explorer
    "explorer.confirmDragAndDrop": false,
    "explorer.decorations.badges": false,
    "explorer.openEditors.visible": 10,
    "explorer.confirmDelete": false,

    "yaml.format.enable": true,
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "python.jediEnabled": false,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "java.errors.incompleteClasspath.severity": "ignore",
    "terraform.indexing": {
        "enabled": false,
        "liveIndexing": false,
        "delay": 500,
        "exclude": [
            ".terraform/**/*",
            "**/.terraform/**/*"
        ]
    },
    "terraform.languageServer": {
        "enabled": true,
        "args": []
    },
    "editor.fontSize": 13,
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontLigatures": true,
    "workbench.preferredDarkColorTheme": "Gruvbox Dark (Medium)",
    "workbench.preferredLightColorTheme": "Gruvbox Light (Medium)",
    "vscode-neovim.neovimPath": "/usr/local/bin/nvim",
    "editor.scrollBeyondLastLine": false,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": true
    },
    "tsimporter.doubleQuotes": true,
    "telemetry.enableTelemetry": false,
    "typescript.surveys.enabled": false
}
