#!/bin/bash

# Welcome to the thoughtbot laptop script!
# Be prepared to turn your laptop (or desktop, no haters here)
# into an awesome development machine.

export BASEDIR=$(dirname $0)
export LIB_FUNCTIONS="${BASEDIR}/lib/functions.sh"
source $LIB_FUNCTIONS

trap 'ret=$?; test $ret -ne 0 && printf "failed\n\n" >&2; exit $ret' EXIT

set -e


if ! command -v brew >/dev/null; then
  fancy_echo "Installing Homebrew ..."
    curl -fsS \
      'https://raw.githubusercontent.com/Homebrew/install/master/install' | ruby

    export PATH="/usr/local/bin:$PATH"
else
  fancy_echo "Homebrew already installed. Skipping ..."
fi

fancy_echo "Updating Homebrew formulas ..."
brew update

brew_install_or_upgrade 'git'
brew_install_or_upgrade 'jq'
brew_install_or_upgrade 'openssl'
brew_install_or_upgrade 'wget'
brew_install_or_upgrade 'fasd'
brew_install_or_upgrade 'httpie'
brew_install_or_upgrade 'sysdig'
brew_install_or_upgrade 'lua'
brew_install_or_upgrade 'bash'
brew_install_or_upgrade 'gnu-sed' '--with-default-names'
brew_install_or_upgrade 'the_silver_searcher'
brew_install_or_upgrade 'vim' '--with-lua'
brew_install_or_upgrade 'ctags'
brew_install_or_upgrade 'tmux'
brew_install_or_upgrade 'reattach-to-user-namespace'
brew_install_or_upgrade 'hub'
brew_install_or_upgrade 'diff-so-fancy'

brew_install_or_upgrade 'python'
brew_install_or_upgrade 'python3'
brew_install_or_upgrade 'pyenv'
brew_install_or_upgrade 'pyenv-virtualenv'
brew_install_or_upgrade 'rbenv'
brew_install_or_upgrade 'ruby-build'
brew_install_or_upgrade 'go'
brew_install_or_upgrade 'glide'
brew_install_or_upgrade 'direnv'

brew_install_or_upgrade 'ssh-copy-id'
brew_install_or_upgrade 'pwgen'
brew_install_or_upgrade 'docker'
brew_install_or_upgrade 'ansible'
brew_install_or_upgrade 'kubernetes-cli'
brew_install_or_upgrade 'packer'
brew_install_or_upgrade 'terraform'
brew_install_or_upgrade 'vault'

brew_install_or_upgrade 'libyaml'

brew_tap 'homebrew/dupes'
brew_install_or_upgrade 'rsync'

brew_tap 'caskroom/cask'
brew_install_or_upgrade 'brew-cask'
brew_cask_install 'iterm2'
brew_cask_install 'java'
brew_cask_install 'virtualbox'
brew_cask_install 'vagrant'
brew_cask_install 'firefox'
brew_cask_install 'google-chrome'
brew_cask_install 'visual-studio-code'

if ! command -v rcup >/dev/null; then
  brew_tap 'thoughtbot/formulae'
  brew_install_or_upgrade 'rcm'
fi

if [ -f "$HOME/.install.local" ]; then
  . "$HOME/.install.local"
fi

git_clone_or_update $HOME/.bash_it https://github.com/Bash-it/bash-it.git
git_clone_or_update $HOME/dotfiles https://github.com/yvigara/dotfiles.git
cd ~/Library/Fonts && curl -fLo "Inconsolata for Powerline Nerd Font Complete Mono.otf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/Inconsolata/complete/Inconsolata%20for%20Powerline%20Nerd%20Font%20Complete%20Mono.otf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Regular/complete/Sauce%20Code%20Pro%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Semibold Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Semibold/complete/Sauce%20Code%20Pro%20Semibold%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Medium Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Medium/complete/Sauce%20Code%20Pro%20Medium%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Light Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Light/complete/Sauce%20Code%20Pro%20Light%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro ExtraLight Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Extra-Light/complete/Sauce%20Code%20Pro%20ExtraLight%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Bold Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Bold/complete/Sauce%20Code%20Pro%20Bold%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
cd ~/Library/Fonts && curl -fLo "Sauce Code Pro Black Nerd Font Complete Mono Windows Compatible.ttf" https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/SourceCodePro/Black/complete/Sauce%20Code%20Pro%20Black%20Nerd%20Font%20Complete%20Mono%20Windows%20Compatible.ttf
git_clone_or_update $HOME/gruvbox-generalized https://github.com/morhetz/gruvbox-generalized.git

mkdir -p $HOME/golang
go get -u github.com/nsf/gocode
go get -u github.com/jstemmer/gotags

go get -u github.com/alecthomas/gometalinter
go get -u golang.org/x/tools/cmd/goimports
go get -u github.com/rogpeppe/godef
go get -u golang.org/x/tools/cmd/guru
go get -u golang.org/x/tools/cmd/gorename
go get -u github.com/golang/lint/golint
go get -u github.com/kisielk/errcheck
go get -u github.com/frairon/go-outline-parser

env RCRC=$HOME/dotfiles/rcrc rcup

bash-it enable plugin alias-completion base docker git go history osx pyenv ssh sshagent virtualenv visual-studio-code fasd
bash-it enable alias ag ansible clipboard curl general git homebrew-cask homebrew osx vault vim
bash-it enable completion bash-it brew defaults docker git go kubectl packer ssh system terraform vagrant vault virtualbox
