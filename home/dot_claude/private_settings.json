{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "editorMode": "vim",
  "permissions": {
    "allow": [
      "mcp__qmd__*",
      "LSP",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout :*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git status:*)",
      "Bash(git worktree:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh auth status:*)",
      "Bash(gh search:*)",
      "Bash(gh label list:*)",
      "Bash(go build:*)",
      "Bash(go generate:*)",
      "Bash(go get:*)",
      "Bash(go mod tidy:*)",
      "Bash(go run:*)",
      "Bash(go test:*)",
      "Bash(go tool:*)",
      "Bash(go version:*)",
      "Bash(golangci-lint:*)",
      "Bash(gopls version:*)",
      "Bash(gopls mcp:*)",
      "Bash(hk:*)",
      "Bash(ls:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Skill(office-hours)",
      "Skill(plan-ceo-review)",
      "Skill(plan-eng-review)",
      "Skill(plan-design-review)",
      "Skill(design-consultation)",
      "Skill(review)",
      "Skill(debug)",
      "Skill(design-review)",
      "Skill(qa)",
      "Skill(qa-only)",
      "Skill(ship)",
      "Skill(document-release)",
      "Skill(retro)",
      "Skill(browse)",
      "Skill(setup-browser-cookies)",
      "Skill(careful)",
      "Skill(freeze)",
      "Skill(guard)",
      "Skill(unfreeze)",
      "Skill(gstack-upgrade)"
    ]
  },
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTO_CONNECT_IDE": "true",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "ccline",
    "padding": 0
  },
  "enabledPlugins": {
    "core@yvigara-marketplace": true,
    "beads@beads-marketplace": true,
    "gopls-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "yvigara-marketplace": {
      "source": {
        "source": "github",
        "repo": "yvigara/claude-plugins"
      }
    },
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "gastownhall/beads"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "git",
      "docker",
      "gh",
      "kubectl"
    ],
    "filesystem": {
      "allowRead": [
        "~/.ssh/known_hosts",
        "~/.ssh/config",
        "~/.config/gh/hosts.yml"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.gnupg",
        "~/.authinfo.gpg",
        "~/.aws/credentials"
      ],
      "denyWrite": [
        "~/.aws",
        "~/.config",
        "~/Library/Keychains"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "proxy.golang.org",
        "sum.golang.org",
        "*.googleapis.com",
        "anthropic.com",
        "*.anthropic.com"
      ],
      "allowLocalBinding": true,
      "allowUnixSockets": [
        "~/.ssh/agent-socket"
      ]
    }
  },
  "preferredNotifChannel": "ghostty",
  "tui": "fullscreen"
}
